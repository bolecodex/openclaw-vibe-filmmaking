# 火山方舟 Ark API（图像 Seedream + 视频 Seedance 共用）
ARK_API_KEY=your-ark-api-key
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# Seedance 2.0 视频生成
SEEDANCE_MODEL=doubao-seedance-2-0-pro-260215

# Seedream 图像生成（Ark）
SEEDREAM_ARK_MODEL=doubao-seedream-4-5-251128

# 火山豆包语音 TTS（配音）
VOLC_APP_ID=your-volc-app-id
VOLC_ACCESS_KEY=your-volc-access-token
# VOLC_TTS_RESOURCE_ID=seed-tts-2.0
# VOLC_TTS_BASE=https://openspeech.bytedance.com

# XSkill MCP API（兼容旧项目：图像/配音可选）
XSKILL_API_KEY=your-xskill-api-key
XSKILL_MCP_URL=https://api.xskill.ai/api/v3/mcp-http
ARK_MODEL_NAME=doubao-seed-2-0-pro-260215
